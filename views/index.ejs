      <!-- UPGRADED PORTION BY ME -->
      <% for(let item of listItems){ 
          const createdDate = new Date(item.created_at);
          const today = new Date();
          const isToday = createdDate.toDateString() === today.toDateString();
      %>

        <div class="item <%= isToday ? 'today-task' : '' %>">

          <form action="/delete" method="post">
            <input type="checkbox" onchange="this.form.submit()" name="deleteItemId" value="<%= item.id %>">
          </form>

          <div class="task-content">
            <p id="title<%=item.id%>"><%= item.title %></p>
            <span class="meta">
              🕒 Added on <%= createdDate.toLocaleString() %>
            </span>
          </div>

          <form class="edit" action="/edit" method="post">
            <input type="hidden" name="updatedItemId" value="<%= item.id %>">
            <input id="input<%=item.id%>" type="text" name="updatedItemTitle"
              value="<%= item.title %>" hidden />
            <button id="done<%=item.id%>" class="edit" type="submit" hidden>
              <img class="icon" src="/assets/icons/check-solid.svg">
            </button>
          </form>

          <button id="edit<%=item.id%>" class="edit action-btn"
            onclick="handler('<%=item.id%>')">
            <img class="icon" src="/assets/icons/pencil-solid.svg">
          </button>

        </div>
      <% } %>


        <form class="item" action="/add" method="post">
          <input type="text" name="newItem" placeholder="New Item" autocomplete="off" autofocus="true" />
          <button class="add" type="submit" name="list" value= "<%=listTitle %>" >+</button>
        </form>
  </div>

  <script>
    function handler(id) {
      document.getElementById("title" + id).setAttribute("hidden", true)
      document.getElementById("edit" + id).setAttribute("hidden", true)
      document.getElementById("done" + id).removeAttribute("hidden")
      document.getElementById("input" + id).removeAttribute("hidden")
    }
  </script>
  <%- include('partials/footer.ejs'); -%>